{
  "kind": "collectionType",
  "collectionName": "job_offers",
  "info": {
    "singularName": "job-offer",
    "pluralName": "job-offers",
    "displayName": "JobOffer",
    "description": "Ofertas de trabajo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "cities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::city.city"
    },
    "remote": {
      "type": "boolean",
      "default": false
    },
    "numberOfPositions": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "publishedFrom": {
      "type": "date",
      "required": true
    },
    "publishedUntil": {
      "type": "date",
      "required": true
    },
    "department": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "cleaning",
        "finance",
        "marketing",
        "sales",
        "systems",
        "maintenance",
        "hospitality",
        "development"
      ]
    }
  }
}
